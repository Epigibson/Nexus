# ─── Antigravity API — Environment Variables ───
# Copy this file to .env and fill in the values.

# ─── Database ───
# Local development (SQLite):
# DATABASE_URL=sqlite+aiosqlite:///./antigravity.db
# Production (Supabase PostgreSQL):
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ─── Supabase ───
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Auth ───
SECRET_KEY=change-this-to-a-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── CORS ───
# JSON array of allowed origins
CORS_ORIGINS=["http://localhost:3000"]

# ─── App ───
DEBUG=false
