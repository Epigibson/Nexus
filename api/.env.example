# ─── Nexus API — Environment Variables ───
# Copy this file to .env and fill in the values.

# ─── Database ───
# --- IMPORTANT: PHASE 1 MIGRATION TO SUPABASE ---
# To activate PostgreSQL globally across Nexus, uncomment the line below.
# Make sure to run `psql -h db.[REF].supabase.co -U postgres -d postgres -f database/migrations/001_initial_schema.sql` to initialize your Database.
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Local development (SQLite fallback):
# DATABASE_URL=sqlite+aiosqlite:///./nexus.db

# ─── Supabase ───
# Find this in your Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Auth ───
SECRET_KEY=change-this-to-a-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── CORS ───
# JSON array of allowed origins
CORS_ORIGINS=["http://localhost:3000"]

# ─── App ───
DEBUG=false
